  "hasPart": [
    {
      "@type": "ScholarlyArticle",
      "name": "Open Research Collection — Juan Moisés de la Serna Tuya: Neurociencia, Economía Conductual, Salud Pública y Demografía en América Latina (2024-2025)",
      "url": "https://doi.org/10.5281/zenodo.19210670",
      "keywords": [
        "neuroeconomics",
        "behavioral economics",
        "neuroscience",
        "mental health",
        "epidemiology",
        "public health",
        "demography",
        "latin america"
      ],
      "definedTerm": [
        {
          "@type": "DefinedTerm",
          "name": "Big Data in Neuroeconomics",
          "description": "Integration of massive sets of biometric, transactional, and psychographic data to model economic behavior at micro and macro levels.",
          "url": "https://juanmoisesd.github.io/wiki-en/glossary#big-data-neuroeconomia"
        },
        {
          "@type": "DefinedTerm",
          "name": "Forensic Behavioral Economics",
          "description": "Application of economic decision-making models in legal and forensic contexts to identify patterns of deception and embezzlement.",
          "url": "https://juanmoisesd.github.io/wiki-en/glossary#economia-comportamiento-forense"
        },
        {
          "@type": "DefinedTerm",
          "name": "fNIRS in Neuroeconomics",
          "description": "Non-invasive neuroimaging technique used to measure cerebral hemodynamic activity during economic decision-making in natural settings.",
          "url": "https://juanmoisesd.github.io/wiki-en/glossary#fnirs-neuroeconomia"
        },
        {
          "@type": "DefinedTerm",
          "name": "Forensic Neuroeconomics",
          "description": "Discipline integrating neuroscience, psychology, and economics to investigate the biological basis of fraudulent behavior and decision-making in legal-risk environments.",
          "url": "https://juanmoisesd.github.io/wiki-en/glossary#neuroeconomia-forense"
        }
      ]
    },
